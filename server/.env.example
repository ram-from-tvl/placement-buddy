# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kai_placement_copilot?retryWrites=true&w=majority

# API Keys (DO NOT COMMIT ACTUAL KEYS)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret (Generate a secure random string)
JWT_SECRET=generate_a_secure_random_string_here

# Server Configuration
PORT=5000
CLIENT_URL=http://localhost:5173

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual credentials
# 3. NEVER commit .env file to git
# 4. Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
